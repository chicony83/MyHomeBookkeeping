<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/buttonPressedOverlay" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="@color/categoryTextSecondary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/buttonNeutralBackground" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="@color/categoryDivider" />
        </shape>
    </item>
</selector>
