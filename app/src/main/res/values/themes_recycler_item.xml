<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="RecyclerViewCard" parent="MatchParent_WrapContent">
        <item name="android:layout_marginTop">@dimen/margin_half_normal</item>
        <item name="android:layout_marginBottom">@dimen/margin_half_normal</item>
        <item name="android:layout_marginStart">@dimen/margin_normal</item>
        <item name="android:layout_marginEnd">@dimen/margin_normal</item>
        <item name="android:paddingStart">@dimen/margin_double</item>
        <item name="android:paddingEnd">@dimen/margin_double</item>
        <item name="android:paddingTop">@dimen/margin_normal</item>
        <item name="android:paddingBottom">@dimen/margin_normal</item>
        <item name="cardElevation">@dimen/margin_half_normal</item>
    </style>
    <style name="RecyclerViewCard.Dialogs">
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:layout_marginBottom">0dp</item>
        <item name="android:layout_marginStart">0dp</item>
        <item name="android:layout_marginEnd">0dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="RecyclerViewCard.ReportsItem">
    </style>

    <style name="RecyclerViewCard.Currencies">
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginStart">@dimen/margin_normal</item>
        <item name="android:layout_marginEnd">@dimen/margin_normal</item>
        <item name="android:layout_marginTop">@dimen/margin_half_normal</item>
        <item name="android:layout_marginBottom">@dimen/margin_half_normal</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/categoryCardBackground</item>
    </style>

    <style name="RecyclerViewCard.CashAccounts">
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginStart">@dimen/margin_normal</item>
        <item name="android:layout_marginEnd">@dimen/margin_normal</item>
        <item name="android:layout_marginTop">@dimen/margin_half_normal</item>
        <item name="android:layout_marginBottom">@dimen/margin_half_normal</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/categoryCardBackground</item>
    </style>

    <style name="RecyclerViewCard.Categories">
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginStart">@dimen/margin_normal</item>
        <item name="android:layout_marginEnd">@dimen/margin_normal</item>
        <item name="android:layout_marginTop">@dimen/margin_half_normal</item>
        <item name="android:layout_marginBottom">@dimen/margin_half_normal</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/categoryCardBackground</item>
    </style>

    <style name="RecyclerViewCard.MoneyMoving">
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginStart">@dimen/margin_normal</item>
        <item name="android:layout_marginEnd">@dimen/margin_normal</item>
        <item name="android:layout_marginTop">@dimen/margin_half_normal</item>
        <item name="android:layout_marginBottom">@dimen/margin_half_normal</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/categoryCardBackground</item>
    </style>

    <style name="RecyclerViewItem" parent="MatchParent_WrapContent">
        <item name="android:elevation">@dimen/margin_half_normal</item>
        <item name="android:paddingStart">@dimen/margin_double</item>
        <item name="android:paddingEnd">@dimen/margin_double</item>
        <item name="android:paddingTop">@dimen/margin_half_normal</item>
        <item name="android:paddingBottom">@dimen/margin_half_normal</item>
    </style>
    <style name="RecyclerViewItem.ParentCategories">
        <item name="android:layout_height">64dp</item>
        <item name="android:textSize">@dimen/H3</item>
        <item name="android:paddingStart">@dimen/margin_normal</item>
        <item name="android:paddingEnd">@dimen/margin_normal</item>
    </style>
    <style name="RecyclerViewItem.Categories">
        <item name="android:layout_height">52dp</item>
        <item name="android:textSize">@dimen/H3</item>
        <item name="android:layout_marginStart">@dimen/margin_double</item>
        <item name="android:layout_marginEnd">@dimen/margin_normal</item>
        <item name="android:layout_marginBottom">@dimen/margin_half_normal</item>
        <item name="android:paddingStart">@dimen/margin_half_normal</item>
        <item name="android:paddingEnd">@dimen/margin_normal</item>
    </style>
    <style name="RecyclerViewItem.Dialogs">
        <item name="android:elevation">0dp</item>
        <item name="android:paddingStart">@dimen/margin_normal</item>
        <item name="android:paddingEnd">@dimen/margin_normal</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="RecyclerViewItem.MoneyMoving">
        <item name="android:paddingStart">@dimen/margin_normal</item>
        <item name="android:paddingEnd">@dimen/margin_normal</item>
        <item name="android:paddingTop">@dimen/margin_normal</item>
        <item name="android:paddingBottom">@dimen/margin_normal</item>
    </style>
</resources>
