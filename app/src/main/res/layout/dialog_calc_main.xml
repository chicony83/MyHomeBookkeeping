<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainConstraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/calculatorExpression"
            style="@style/RobotoFontCondensedMedium"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:background="@drawable/input_field_background"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textColor="@color/text_color"
            android:textSize="34sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/calculatorResult"
            style="@style/RobotoFontCondensedMedium"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textColor="@color/text_second_color"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/calculatorExpression" />

        <TextView
            android:id="@+id/historyFirst"
            style="@style/RobotoFontCondensedMedium"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:background="@drawable/button_filter_background"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:paddingHorizontal="10dp"
            android:singleLine="true"
            android:textColor="@color/categoryTextSecondary"
            android:textSize="15sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/calculatorResult" />

        <TextView
            android:id="@+id/historySecond"
            style="@style/RobotoFontCondensedMedium"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/button_filter_background"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:paddingHorizontal="10dp"
            android:singleLine="true"
            android:textColor="@color/categoryTextSecondary"
            android:textSize="15sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/historyFirst" />

        <LinearLayout
            android:id="@+id/keypad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/historySecond">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonClear"
                    style="@style/SimpleCalculatorButton.Neutral"
                    android:text="@string/clear" />

                <Button
                    android:id="@+id/buttonParentheses"
                    style="@style/SimpleCalculatorButton.Neutral"
                    android:text="()" />

                <Button
                    android:id="@+id/buttonPercent"
                    style="@style/SimpleCalculatorButton.Neutral"
                    android:text="%" />

                <Button
                    android:id="@+id/buttonDivide"
                    style="@style/SimpleCalculatorButton.Operator"
                    android:text="/" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button7"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/seven" />

                <Button
                    android:id="@+id/button8"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/eight" />

                <Button
                    android:id="@+id/button9"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/nine" />

                <Button
                    android:id="@+id/buttonMultiply"
                    style="@style/SimpleCalculatorButton.Operator"
                    android:text="*" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button4"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/four" />

                <Button
                    android:id="@+id/button5"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/five" />

                <Button
                    android:id="@+id/button6"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/six" />

                <Button
                    android:id="@+id/buttonSubtract"
                    style="@style/SimpleCalculatorButton.Operator"
                    android:text="-" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button1"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/one" />

                <Button
                    android:id="@+id/button2"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/two" />

                <Button
                    android:id="@+id/button3"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/three" />

                <Button
                    android:id="@+id/buttonAdd"
                    style="@style/SimpleCalculatorButton.Operator"
                    android:text="+" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonBackspace"
                    style="@style/SimpleCalculatorButton.Neutral"
                    android:text="⌫" />

                <Button
                    android:id="@+id/button0"
                    style="@style/SimpleCalculatorButton"
                    android:text="@string/zero" />

                <Button
                    android:id="@+id/buttonPoint"
                    style="@style/SimpleCalculatorButton"
                    android:text="." />

                <Button
                    android:id="@+id/buttonEquals"
                    style="@style/SimpleCalculatorButton.Primary"
                    android:text="=" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
