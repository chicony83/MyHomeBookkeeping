<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Fragment.paddingBottom"
    android:background="@color/categoryScreenBackground"
    tools:context=".ui.paymentPackage.newMoneyMoving.NewMoneyMovingFragment">

    <ScrollView
        style="@style/MoneyMovingScrollView"
        android:clipToPadding="false"
        android:padding="@dimen/margin_normal"
        app:layout_constraintBottom_toTopOf="@+id/submitButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/category_group_background"
            android:orientation="vertical"
            android:padding="@dimen/margin_normal">

            <TextView
                style="@style/TextDescriptions"
                android:textColor="@color/categoryTextSecondary"
                android:textSize="@dimen/H5"
                android:text="@string/description_date_time_text" />

            <Button
                android:id="@+id/selectDateTimeButton"
                style="@style/ButtonFullWidth"
                android:layout_marginTop="@dimen/margin_half_normal" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/paymentTypeToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_normal"
                app:checkedButton="@id/paymentModeButton"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/paymentModeButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/text_on_button_payment" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/transferModeButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/text_on_button_transfer_between_accounts" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:id="@+id/sourceCashAccountLabel"
                style="@style/TextDescriptions"
                android:layout_marginTop="@dimen/margin_normal"
                android:textColor="@color/categoryTextSecondary"
                android:textSize="@dimen/H5"
                android:text="@string/description_cash_account_from" />

            <Button
                android:id="@+id/selectCashAccountButton"
                style="@style/ButtonFullWidth"
                android:text="@string/text_on_button_select_cash_account" />

            <HorizontalScrollView
                android:id="@+id/cashAccountQuickSelectScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/cashAccountQuickSelectRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/destinationCashAccountLabel"
                style="@style/TextDescriptions"
                android:layout_marginTop="@dimen/margin_normal"
                android:textColor="@color/categoryTextSecondary"
                android:textSize="@dimen/H5"
                android:text="@string/description_cash_account_to"
                android:visibility="gone"
                tools:visibility="visible" />

            <Button
                android:id="@+id/selectTransferCashAccountButton"
                style="@style/ButtonFullWidth"
                android:text="@string/text_on_button_select_cash_account"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/categoryLabel"
                style="@style/TextDescriptions"
                android:layout_marginTop="@dimen/margin_normal"
                android:textColor="@color/categoryTextSecondary"
                android:textSize="@dimen/H5"
                android:text="@string/description_currency" />

            <Button
                android:id="@+id/selectCurrenciesButton"
                style="@style/ButtonFullWidth"
                android:text="@string/text_on_button_select_currency" />

            <HorizontalScrollView
                android:id="@+id/currencyQuickSelectScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/currencyQuickSelectRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                style="@style/TextDescriptions"
                android:layout_marginTop="@dimen/margin_normal"
                android:textColor="@color/categoryTextSecondary"
                android:textSize="@dimen/H5"
                android:text="@string/description_category" />

            <Button
                android:id="@+id/selectCategoryButton"
                style="@style/ButtonFullWidth"
                android:text="@string/text_on_button_select_category" />

            <TextView
                style="@style/TextDescriptions"
                android:layout_marginTop="@dimen/margin_normal"
                android:textColor="@color/categoryTextSecondary"
                android:textSize="@dimen/H5"
                android:text="@string/description_amount" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/amountInputContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_field_background"
                android:paddingTop="@dimen/margin_half_normal"
                android:paddingBottom="@dimen/margin_half_normal"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/amountEditText"
                    style="@style/EditTextAmount"
                    android:layout_width="0dp"
                    android:background="@null"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/eraseButton"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/eraseButton"
                    android:layout_width="40dp"
                    android:layout_height="50dp"
                    android:background="?android:selectableItemBackground"
                    android:contentDescription="@string/content_description_erase_button"
                    android:src="@drawable/button_clear"
                    app:tint="@color/inputText"
                    app:layout_constraintEnd_toStartOf="@id/calc_button"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/calc_button"
                    android:layout_width="40dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="@dimen/margin_normal"
                    android:background="?android:selectableItemBackground"
                    android:contentDescription="@string/content_description_erase_button"
                    android:src="@drawable/ic_outline_calc"
                    app:tint="@color/inputText"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/amountScrollContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingTop="@dimen/margin_half_normal"
                android:paddingBottom="@dimen/margin_half_normal"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/amountWholeGroup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/decreaseAmountWholeDigitsButton"
                        android:layout_width="44dp"
                        android:layout_height="120dp"
                        android:text="-"
                        android:textSize="@dimen/H3" />

                    <HorizontalScrollView
                        android:id="@+id/amountWholeDigitsScroll"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:clipToPadding="false"
                        android:fillViewport="false"
                        android:overScrollMode="ifContentScrolls">

                        <LinearLayout
                            android:id="@+id/amountWholeDigitsRow"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <Button
                        android:id="@+id/increaseAmountWholeDigitsButton"
                        android:layout_width="44dp"
                        android:layout_height="120dp"
                        android:text="+"
                        android:textSize="@dimen/H3" />
                </LinearLayout>

                <TextView
                    android:id="@+id/amountDecimalSeparator"
                    style="@style/Header"
                    android:layout_width="wrap_content"
                    android:layout_height="120dp"
                    android:gravity="center"
                    android:paddingStart="@dimen/margin_normal"
                    android:paddingEnd="@dimen/margin_normal"
                    android:text="."
                    android:textColor="@color/inputText" />

                <LinearLayout
                    android:id="@+id/amountFractionGroup"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <HorizontalScrollView
                        android:id="@+id/amountFractionDigitsScroll"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:fillViewport="false"
                        android:overScrollMode="ifContentScrolls">

                        <LinearLayout
                            android:id="@+id/amountFractionDigitsRow"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/TextDescriptions"
                android:layout_marginTop="@dimen/margin_normal"
                android:textColor="@color/categoryTextSecondary"
                android:textSize="@dimen/H5"
                android:text="@string/description_description" />

            <EditText
                android:id="@+id/description"
                style="@style/EditTextDescription" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/submitButton"
        style="@style/ButtonFullWidth"
        android:background="@drawable/button_primary_background"
        android:backgroundTint="@null"
        android:gravity="center"
        android:layout_marginHorizontal="@dimen/margin_normal"
        android:textColor="@color/buttonPrimaryText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
