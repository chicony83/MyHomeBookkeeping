<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools"
    style="@style/RecyclerViewCard.Currencies">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/currenciesItem"
        style="@style/RecyclerViewItem.ParentCategories"
        android:background="@drawable/category_group_background"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/nameShortCurrency"
            style="@style/TextView.RecyclerViewHorizontalItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/margin_normal"
            android:textColor="@color/categoryTextSecondary"
            android:textSize="@dimen/H5"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tool:text="$" />

        <TextView
            android:id="@+id/nameCurrency"
            style="@style/TextView.RecyclerViewHorizontalItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:maxLines="2"
            android:textAlignment="viewStart"
            android:textColor="@color/black"
            android:textSize="@dimen/H5"
            app:layout_constraintBottom_toBottomOf="@id/iSOCurrency"
            app:layout_constraintEnd_toStartOf="@id/nameShortCurrency"
            app:layout_constraintStart_toEndOf="@id/iSOCurrency"
            app:layout_constraintTop_toTopOf="@id/iSOCurrency"
            tool:text="Dollar" />

        <TextView
            android:id="@+id/iSOCurrency"
            style="@style/TextView.RecyclerViewHorizontalItem"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/margin_normal"
            android:gravity="center"
            android:textColor="@color/colorPrimaryVariant"
            android:textSize="@dimen/H5"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tool:text="USD" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
